{
  "name": "withremote-sync",
  "version": "1.0.0",
  "description": "Multi-source sync pipeline and metrics service",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "worker": "node src/queue/worker.js",
    "migrate": "node scripts/migrate.js",
    "seed:hubspot": "node scripts/seed_hubspot.js",
    "seed:stripe": "node scripts/seed_stripe.js",
    "seed:gcal": "node scripts/seed_gcal.js",
    "seed": "npm run seed:hubspot && npm run seed:stripe && npm run seed:gcal",
    "gcal:auth": "node scripts/gcal_auth.js",
    "test": "jest --testEnvironment node --forceExit"
  },
  "dependencies": {
    "@hubspot/api-client": "^11.2.0",
    "bullmq": "^5.7.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^140.0.1",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
