# Database (Supabase)
DATABASE_URL=postgresql://postgres:[password]@[host].supabase.co:5432/postgres

# Redis — Upstash free tier (rediss://) or local (redis://)
REDIS_URL=redis://localhost:6379

# HubSpot — Private App token
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe — Test mode secret key
STRIPE_SECRET_KEY=your_stripe_test_secret_key_here

# Google Calendar OAuth2
GCAL_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GCAL_CLIENT_SECRET=GOCSPX-xxxxxxxx
GCAL_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx
GCAL_CALENDAR_ID=primary

# Server
PORT=3000
